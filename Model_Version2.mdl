"Delay on Suppy-Demand dynamics for Country Profile"=
	IF THEN ELSE (
	Fuel Selection=1, 
	0.9, 
	
	IF THEN ELSE (
	Fuel Selection=2, 0.7, 
	
	IF THEN ELSE (
	
	Fuel Selection=3, 
	
	0.2, 
	
	0.5
	)
	
	)
	
	
	)
	~	
	~		|

Effect of regulatory Landscape on Country Profile=
	delay time on effect of regulatory landscape on country profile*Effect of Regulatory Environment on Regulatory Landscape
	~	
	~		|

delay time on effect of regulatory landscape on country profile=
	IF THEN ELSE (
	Fuel Selection=1, 
	0.8, 
	
	IF THEN ELSE (
	Fuel Selection=2, 0.5, 
	
	IF THEN ELSE (
	
	Fuel Selection=3, 
	
	0.1, 
	
	0.3
	)
	
	)
	
	
	)
	~	
	~		|

